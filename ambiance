*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--dark);
  color: var(--light);
  font-family: 'Jost', sans-serif;
  overflow-x: hidden;
  cursor: none;
}

/* Curseur */
.cursor {
  width: 11px; height: 11px;
  background: var(--accent);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%, -50%);
  transition: width 0.3s, height 0.3s, background 0.3s;
}
.cursor-ring {
  width: 34px; height: 34px;
  border: 1.5px solid var(--sage);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 9998;
  transform: translate(-50%, -50%);
  transition: width 0.3s, height 0.3s, border-color 0.3s;
}
.cursor.hover { width: 18px; height: 18px; background: var(--sage); }
.cursor-ring.hover { width: 52px; height: 52px; border-color: var(--accent); }

/* Grain */
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.045'/%3E%3C/svg%3E");
  background-size: 256px;
  pointer-events: none;
  z-index: 1000;
  opacity: 0.5;
}

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 500;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.6rem 4rem;
  background: linear-gradient(to bottom, rgba(11,20,11,0.97) 0%, transparent 100%);
}
.logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--cream);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.7rem;
  letter-spacing: 0.01em;
}
.logo-icon {
  width: 32px; height: 32px;
  position: relative;
  flex-shrink: 0;
}
.logo-icon svg { width: 100%; height: 100%; }
.logo span { color: var(--sage); }

nav ul { list-style: none; display: flex; gap: 2.5rem; align-items: center; }
nav ul a {
  color: var(--light);
  text-decoration: none;
  font-size: 0.8rem;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  opacity: 0.6;
  transition: opacity 0.2s;
}
nav ul a:hover { opacity: 1; }
.nav-btn {
  background: var(--olive) !important;
  color: var(--cream) !important;
  opacity: 1 !important;
  padding: 0.55rem 1.4rem;
  border-radius: 100px;
  transition: background 0.2s, transform 0.2s !important;
}
.nav-btn:hover { background: var(--moss) !important; transform: translateY(-2px); }

/* ── HERO ── */
#hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0 4rem 6rem;
  position: relative;
  overflow: hidden;
}

/* Background radial glows */
.glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  pointer-events: none;
}
.glow-1 {
  width: 700px; height: 700px;
  background: radial-gradient(circle, rgba(92,110,42,0.45) 0%, transparent 70%);
  top: -150px; right: -150px;
  animation: breathe 10s ease-in-out infinite;
}
.glow-2 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(26,46,26,0.8) 0%, transparent 70%);
  bottom: 0; left: 0;
  animation: breathe 12s ease-in-out infinite reverse;
}
.glow-3 {
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(164,184,106,0.2) 0%, transparent 70%);
  top: 40%; left: 35%;
  animation: breathe 8s ease-in-out infinite 2s;
}
@keyframes breathe {
  0%, 100% { transform: scale(1) translate(0, 0); }
  50% { transform: scale(1.12) translate(20px, -20px); }
}

/* Feuille décorative SVG flottante */
.leaf-deco {
  position: absolute;
  top: 15%; right: 8%;
  width: 320px;
  opacity: 0.12;
  animation: leafFloat 14s ease-in-out infinite;
}
@keyframes leafFloat {
  0%, 100% { transform: rotate(-5deg) translateY(0); }
  50% { transform: rotate(3deg) translateY(-20px); }
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-size: 0.75rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--sage);
  margin-bottom: 2rem;
  opacity: 0;
  animation: fadeUp 0.9s 0.2s forwards;
}
.hero-eyebrow::before {
  content: '';
  display: block;
  width: 40px; height: 1px;
  background: var(--sage);
}

.hero-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(4rem, 9vw, 9.5rem);
  font-weight: 700;
  line-height: 0.92;
  letter-spacing: -0.02em;
  margin-bottom: 2.5rem;
  opacity: 0;
  animation: fadeUp 0.9s 0.4s forwards;
}
.hero-title em {
  font-style: italic;
  color: var(--sage);
}
.hero-title .outline {
  color: transparent;
  -webkit-text-stroke: 1.5px var(--olive);
}

.hero-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
}

.hero-sub {
  max-width: 420px;
  font-size: 1rem;
  line-height: 1.75;
  color: rgba(228,232,208,0.6);
  opacity: 0;
  animation: fadeUp 0.9s 0.6s forwards;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  align-items: center;
  opacity: 0;
  animation: fadeUp 0.9s 0.8s forwards;
}
.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  background: var(--olive);
  color: var(--cream);
  text-decoration: none;
  font-size: 0.88rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  padding: 1rem 2rem;
  border-radius: 100px;
  transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
}
.btn-primary:hover {
  background: var(--moss);
  transform: translateY(-3px);
  box-shadow: 0 14px 35px rgba(92,110,42,0.45);
}
.btn-primary svg { transition: transform 0.2s; }
.btn-primary:hover svg { transform: translateX(4px); }

.btn-ghost {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  color: var(--light);
  text-decoration: none;
  font-size: 0.85rem;
  letter-spacing: 0.08em;
  opacity: 0.6;
  transition: opacity 0.2s;
}
.btn-ghost:hover { opacity: 1; }

.hero-stats {
  display: flex;
  gap: 3rem;
  opacity: 0;
  animation: fadeUp 0.9s 1s forwards;
  padding-bottom: 0.3rem;
}
.stat-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.4rem;
  font-weight: 700;
  color: var(--accent);
  line-height: 1;
}
.stat-label {
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(228,232,208,0.45);
  margin-top: 0.25rem;
}

.scroll-line {
  position: absolute;
  bottom: 0; left: 4rem;
  width: 1px; height: 80px;
  background: linear-gradient(to bottom, var(--olive), transparent);
  opacity: 0;
  animation: fadeIn 1s 1.4s forwards;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(35px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  to { opacity: 1; }
}

/* ── MARQUEE ── */
.marquee-wrap {
  overflow: hidden;
  border-top: 1px solid rgba(92,110,42,0.25);
  border-bottom: 1px solid rgba(92,110,42,0.25);
  padding: 1rem 0;
  background: rgba(26,46,26,0.4);
}
.marquee-track {
  display: flex;
  animation: marquee 22s linear infinite;
  white-space: nowrap;
}
.marquee-item {
  display: inline-flex;
  align-items: center;
  gap: 1.2rem;
  padding: 0 2rem;
  font-family: 'Cormorant Garamond', serif;
  font-size: 1rem;
  font-style: italic;
  color: rgba(164,184,106,0.5);
  letter-spacing: 0.04em;
}
.marquee-leaf {
  width: 18px; height: 18px;
  fill: var(--olive);
}
@keyframes marquee {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

/* ── SERVICES ── */
#services {
  padding: 8rem 4rem;
  background: var(--deep);
  position: relative;
}
#services::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(to right, transparent, var(--olive), transparent);
}

.section-tag {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  font-size: 0.72rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--sage);
  margin-bottom: 1rem;
}
.section-tag::before {
  content: '';
  width: 30px; height: 1px;
  background: var(--sage);
}
.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.4rem, 5vw, 4.5rem);
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.02em;
  margin-bottom: 4rem;
}
.section-title em { font-style: italic; color: var(--sage); }

.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5px;
  border: 1.5px solid rgba(92,110,42,0.2);
  border-radius: 20px;
  overflow: hidden;
}
.service-card {
  padding: 2.5rem 2rem;
  background: var(--forest);
  position: relative;
  transition: background 0.3s;
  border-right: 1.5px solid rgba(92,110,42,0.15);
  border-bottom: 1.5px solid rgba(92,110,42,0.15);
}
.service-card:nth-child(3n) { border-right: none; }
.service-card:nth-child(4),
.service-card:nth-child(5),
.service-card:nth-child(6) { border-bottom: none; }
.service-card:hover { background: #1f361f; }

.service-icon {
  width: 52px; height: 52px;
  border-radius: 14px;
  background: rgba(92,110,42,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 2rem;
  transition: background 0.3s;
}
.service-card:hover .service-icon { background: rgba(92,110,42,0.4); }
.service-icon svg { width: 26px; height: 26px; stroke: var(--sage); fill: none; stroke-width: 1.5; }

.service-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.6rem;
  font-weight: 600;
  margin-bottom: 1rem;
  color: var(--cream);
}
.service-desc {
  font-size: 0.88rem;
  line-height: 1.75;
  color: rgba(228,232,208,0.5);
}
.service-num {
  position: absolute;
  top: 2rem; right: 2rem;
  font-family: 'Cormorant Garamond', serif;
  font-size: 4rem;
  font-weight: 700;
  color: rgba(92,110,42,0.12);
  line-height: 1;
}

/* ── PROJETS ── */
#projets {
  padding: 8rem 4rem;
  position: relative;
}

.projects-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 4rem;
  flex-wrap: wrap;
  gap: 1.5rem;
}
.view-all {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.82rem;
  letter-spacing: 0.1em;
  color: var(--sage);
  text-decoration: none;
  text-transform: uppercase;
  transition: gap 0.2s;
}
.view-all:hover { gap: 0.9rem; }

.projects-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  grid-template-rows: auto auto;
  gap: 1.5rem;
}

.proj {
  border-radius: 18px;
  overflow: hidden;
  position: relative;
  cursor: none;
}
.proj:nth-child(1) { grid-column: span 7; aspect-ratio: 16/10; }
.proj:nth-child(2) { grid-column: span 5; aspect-ratio: 4/3; }
.proj:nth-child(3) { grid-column: span 4; aspect-ratio: 4/3; }
.proj:nth-child(4) { grid-column: span 8; aspect-ratio: 16/9; }

.proj-bg {
  position: absolute; inset: 0;
  transition: transform 0.6s cubic-bezier(0.16,1,0.3,1);
}
.proj:hover .proj-bg { transform: scale(1.07); }

/* Backgrounds jardins simulés avec CSS */
.proj-bg-1 {
  background:
    radial-gradient(ellipse at 30% 70%, rgba(26,46,26,0.8) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 20%, rgba(92,110,42,0.6) 0%, transparent 50%),
    linear-gradient(160deg, #0f2010 0%, #2d4a1e 40%, #1a3020 70%, #0d1a0d 100%);
}
.proj-bg-2 {
  background:
    radial-gradient(ellipse at 60% 40%, rgba(122,142,58,0.5) 0%, transparent 60%),
    linear-gradient(135deg, #162816 0%, #3a5220 50%, #1e3a14 100%);
}
.proj-bg-3 {
  background:
    radial-gradient(ellipse at 40% 60%, rgba(92,110,42,0.6) 0%, transparent 55%),
    linear-gradient(120deg, #1a3018 0%, #2a4818 50%, #162410 100%);
}
.proj-bg-4 {
  background:
    radial-gradient(ellipse at 70% 50%, rgba(164,184,106,0.2) 0%, transparent 50%),
    linear-gradient(150deg, #0d1a0d 0%, #1e3a1e 40%, #2d4a1e 70%, #111e11 100%);
}

/* Motifs végétaux décoratifs */
.proj-pattern {
  position: absolute; inset: 0;
  opacity: 0.18;
}

.proj-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(11,20,11,0.85) 0%, rgba(11,20,11,0.1) 55%, transparent 100%);
  transition: background 0.3s;
}
.proj:hover .proj-overlay {
  background: linear-gradient(to top, rgba(11,20,11,0.92) 0%, rgba(11,20,11,0.3) 60%, transparent 100%);
}

.proj-content {
  position: absolute; inset: 0;
  padding: 2rem;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.proj-tag {
  display: inline-block;
  font-size: 0.68rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  background: rgba(92,110,42,0.35);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(164,184,106,0.2);
  padding: 0.3rem 0.9rem;
  border-radius: 100px;
  margin-bottom: 0.8rem;
  width: fit-content;
  color: var(--sage);
}
.proj-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.8rem;
  font-weight: 700;
  line-height: 1.1;
  color: var(--cream);
  margin-bottom: 0.5rem;
}
.proj-detail {
  font-size: 0.83rem;
  color: rgba(228,232,208,0.55);
  line-height: 1.5;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease;
}
.proj:hover .proj-detail { max-height: 50px; }
.proj-arrow {
  position: absolute;
  top: 1.5rem; right: 1.5rem;
  width: 40px; height: 40px;
  border-radius: 50%;
  background: rgba(92,110,42,0.3);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(164,184,106,0.25);
  display: flex; align-items: center; justify-content: center;
  opacity: 0;
  transform: scale(0.7) rotate(-45deg);
  transition: opacity 0.3s, transform 0.3s;
}
.proj:hover .proj-arrow { opacity: 1; transform: scale(1) rotate(0deg); }

/* ── ABOUT ── */
#about {
  padding: 8rem 4rem;
  background: var(--deep);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rem;
  align-items: center;
  position: relative;
}
#about::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(to right, transparent, var(--olive), transparent);
}

.about-visual {
  position: relative;
}
.about-card {
  border-radius: 24px;
  background: linear-gradient(145deg, #1e3a1e 0%, #0f2010 60%, #162a10 100%);
  border: 1px solid rgba(92,110,42,0.25);
  aspect-ratio: 3/4;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}
.about-card-inner {
  position: absolute; inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.about-card-inner svg {
  width: 60%;
  opacity: 0.15;
}
.about-badge {
  position: absolute;
  bottom: 2rem; left: 50%;
  transform: translateX(-50%);
  background: rgba(92,110,42,0.3);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(164,184,106,0.2);
  border-radius: 16px;
  padding: 1.2rem 2rem;
  text-align: center;
  white-space: nowrap;
}
.about-badge-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.2rem;
  font-weight: 700;
  color: var(--accent);
  line-height: 1;
}
.about-badge-text {
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(228,232,208,0.5);
  margin-top: 0.2rem;
}
.about-float {
  position: absolute;
  top: -1.5rem; right: -1.5rem;
  width: 90px; height: 90px;
  border-radius: 50%;
  background: rgba(92,110,42,0.15);
  border: 1px solid rgba(92,110,42,0.3);
  display: flex; align-items: center; justify-content: center;
}
.about-float svg { width: 40px; height: 40px; fill: var(--sage); opacity: 0.7; }

.about-content {}
.about-content p {
  font-size: 1rem;
  line-height: 1.85;
  color: rgba(228,232,208,0.6);
  margin-bottom: 1.5rem;
}
.about-values {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-top: 2.5rem;
}
.value-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem 1.4rem;
  background: rgba(26,46,26,0.5);
  border: 1px solid rgba(92,110,42,0.15);
  border-radius: 12px;
  transition: border-color 0.2s, background 0.2s;
}
.value-row:hover {
  border-color: rgba(92,110,42,0.4);
  background: rgba(26,46,26,0.8);
}
.value-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
}
.value-text {
  font-size: 0.9rem;
  color: var(--light);
}

/* ── CONTACT ── */
#contact {
  padding: 8rem 4rem;
  position: relative;
  overflow: hidden;
}
#contact::before {
  content: '';
  position: absolute;
  width: 800px; height: 800px;
  background: radial-gradient(circle, rgba(92,110,42,0.12) 0%, transparent 70%);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.contact-wrap {
  max-width: 760px;
  margin: 0 auto;
}
.contact-intro {
  text-align: center;
  margin-bottom: 4rem;
}
.contact-intro .section-tag { justify-content: center; }
.contact-intro .section-title { margin-bottom: 1rem; }
.contact-intro p {
  font-size: 1rem;
  color: rgba(228,232,208,0.5);
  line-height: 1.75;
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
}
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
.form-group { display: flex; flex-direction: column; gap: 0.5rem; }
.form-group label {
  font-size: 0.72rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(228,232,208,0.4);
}
.form-group input,
.form-group textarea,
.form-group select {
  background: rgba(26,46,26,0.6);
  border: 1px solid rgba(92,110,42,0.2);
  border-radius: 14px;
  padding: 1rem 1.3rem;
  color: var(--light);
  font-family: 'Jost', sans-serif;
  font-size: 0.92rem;
  outline: none;
  width: 100%;
  transition: border-color 0.25s, background 0.25s;
  -webkit-appearance: none;
}
.form-group input:focus,
.form-group textarea:focus,
.form-group select:focus {
  border-color: var(--olive);
  background: rgba(26,46,26,0.9);
}
.form-group textarea { resize: vertical; min-height: 140px; }
.form-group select option { background: #1a3018; }

.form-submit-wrap {
  display: flex;
  justify-content: center;
  margin-top: 0.5rem;
}
.form-submit {
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  background: var(--olive);
  color: var(--cream);
  border: none;
  border-radius: 100px;
  padding: 1.1rem 2.8rem;
  font-family: 'Jost', sans-serif;
  font-size: 0.92rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  cursor: none;
  transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
}
.form-submit:hover {
  background: var(--moss);
  transform: translateY(-3px);
  box-shadow: 0 14px 35px rgba(92,110,42,0.4);
}

/* Infos contact */
.contact-infos {
  display: flex;
  justify-content: center;
  gap: 3rem;
  margin-top: 3.5rem;
  flex-wrap: wrap;
}
.contact-info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  text-align: center;
}
.info-icon {
  width: 42px; height: 42px;
  border-radius: 50%;
  background: rgba(92,110,42,0.15);
  border: 1px solid rgba(92,110,42,0.25);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 0.3rem;
}
.info-icon svg { width: 18px; height: 18px; stroke: var(--sage); fill: none; stroke-width: 1.5; }
.info-label {
  font-size: 0.68rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(228,232,208,0.35);
}
.info-val {
  font-size: 0.9rem;
  color: var(--light);
}

/* ── FOOTER ── */
footer {
  border-top: 1px solid rgba(92,110,42,0.2);
  padding: 2.5rem 4rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
  background: var(--deep);
}
.footer-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--cream);
  text-decoration: none;
}
.footer-logo span { color: var(--sage); }
.footer-copy { font-size: 0.78rem; color: rgba(228,232,208,0.3); }
.footer-links { display: flex; gap: 2rem; }
.footer-links a {
  font-size: 0.78rem;
  color: rgba(228,232,208,0.4);
  text-decoration: none;
  transition: color 0.2s;
}
.footer-links a:hover { color: var(--sage); }

/* Toast */
.toast {
  position: fixed;
  bottom: 2rem; left: 50%;
  transform: translateX(-50%) translateY(120px);
  background: var(--moss);
  color: var(--dark);
  padding: 1rem 2rem;
  border-radius: 100px;
  font-weight: 600;
  font-size: 0.88rem;
  z-index: 800;
  transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
  letter-spacing: 0.05em;
}
.toast.show { transform: translateX(-50%) translateY(0); }

/* Scroll reveal */
.reveal {
  opacity: 0;
  transform: translateY(35px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}
.reveal.visible { opacity: 1; transform: translateY(0); }

@media (max-width: 900px) {
  nav { padding: 1.2rem 1.5rem; }
  nav ul { display: none; }
  #hero, #services, #projets, #contact { padding: 6rem 1.5rem 4rem; }
  #about { grid-template-columns: 1fr; padding: 5rem 1.5rem; gap: 3rem; }
  .projects-grid { grid-template-columns: 1fr; }
  .proj:nth-child(n) { grid-column: span 1; aspect-ratio: 4/3; }
  .services-grid { grid-template-columns: 1fr; }
  .service-card { border-right: none; border-bottom: 1.5px solid rgba(92,110,42,0.15); }
  .form-row { grid-template-columns: 1fr; }
  footer { flex-direction: column; text-align: center; }
  .projects-header { flex-direction: column; align-items: flex-start; }
}
